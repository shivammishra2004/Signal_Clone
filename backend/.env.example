# Backend Environment Variables
# Copy this file to .env and fill in your values

# ─── Database ─────────────────────────────────────────────────────────────────
# Local SQLite (default, no setup needed for development):
DATABASE_URL=sqlite+aiosqlite:///./app.db

# PostgreSQL via Neon / Supabase (for production):
# DATABASE_URL=postgresql+asyncpg://username:password@host/dbname?ssl=require

# ─── Security ─────────────────────────────────────────────────────────────────
# IMPORTANT: Generate a strong random secret for production.
# Run: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=supersecret-dev-key-change-in-production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Local and Production:
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ─── Frontend URL ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── API Base URL ─────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000

# ─── Cloud Storage (Attachments) ──────────────────────────────────────────────
# Supabase credentials for storing uploaded files and images
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key
SUPABASE_BUCKET=chat-attachments
